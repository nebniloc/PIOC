{
  "name": "pioc",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "vite --mode development",
    "build": "pnpm run build:prod",
    "build:dev": "svelte-check --tsconfig ./tsconfig.json && vite build --mode development",
    "build:prod": "svelte-check --tsconfig ./tsconfig.json && vite build --mode production",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test:js": "pnpm run check && pnpm run typecheck",
    "test:rust": "cd src-tauri && cargo test",
    "test": "pnpm run test:js && pnpm run test:rust",
    "format:check": "cd src-tauri && cargo fmt --check",
    "lint:rust": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "lint": "pnpm run format:check && pnpm run lint:rust",
    "version:check": "node scripts/check-version.mjs",
    "ci": "pnpm run version:check && pnpm run lint && pnpm run test && pnpm run build && cd src-tauri && cargo check",
    "prepare:prod-config": "node scripts/prepare-prod-tauri-config.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev --config src-tauri/tauri.dev.conf.json",
    "tauri:build:dev": "tauri build --config src-tauri/tauri.dev.conf.json",
    "tauri:build:prod": "pnpm run prepare:prod-config && tauri build --config src-tauri/tauri.prod.generated.conf.json",
    "app:dev": "pnpm run tauri:dev",
    "app:build:dev": "pnpm run tauri:build:dev",
    "app:build:prod": "pnpm run tauri:build:prod"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@wterm/dom": "^0.3.0",
    "svelte-dnd-action": "^0.9.69",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@internationalized/date": "^3.12.2",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "remixicon-svelte": "^0.0.5",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.6.2",
    "vite": "^8.0.16"
  }
}

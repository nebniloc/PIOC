{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PIOC",
  "identifier": "com.pioc.app",
  "build": {
    "beforeBuildCommand": "pnpm build:prod"
  },
  "app": {
    "windows": [
      {
        "title": "PIOC",
        "width": 800,
        "height": 600
      }
    ]
  },
  "bundle": {
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "__TAURI_UPDATER_PUBLIC_KEY__",
      "endpoints": ["__PIOC_UPDATE_ENDPOINT__"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
